PORT=5000

# Provider selection: openrouter | openai
LLM_PROVIDER=openrouter

# Debug/diagnostics
# true -> fail fast when LLM call fails instead of mock fallback
LLM_STRICT_MODE=false

# Generic fallback keys (optional)
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# OpenRouter settings
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:5000
OPENROUTER_APP_TITLE=AI Terminal POC

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
